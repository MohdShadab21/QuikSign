{
  "name": "quiksign",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-deploy-env.mjs && node scripts/copy-pdf-worker.mjs && next dev -p 3030",
    "prebuild": "node scripts/ensure-deploy-env.mjs && node scripts/copy-pdf-worker.mjs && prisma generate && prisma migrate deploy",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/ensure-deploy-env.mjs && node scripts/copy-pdf-worker.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@react-pdf/renderer": "^4.5.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "libreoffice-convert": "^1.8.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
