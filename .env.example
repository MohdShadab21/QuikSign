# --- Required ---
# Postgres connection string (use Neon/Supabase/Railway pooled URL for Vercel)
# On Vercel + Prisma Postgres storage, you can omit this — ensure-deploy-env.mjs maps
# POSTGRES_URL / DATABASE_URL_POSTGRES_URL / DATABASE_URL_DATABASE_URL → DATABASE_URL
DATABASE_URL=

# Canonical public URL (signing links in emails + API responses)
# Local:  http://localhost:3030
# Vercel: optional — scripts/ensure-deploy-env.mjs sets this from VERCEL_PROJECT_PRODUCTION_URL on build
#         lib/utils/app-url.ts also uses the request host at runtime (ignores localhost on Vercel)
NEXT_PUBLIC_APP_URL=

# Optional server-only alias (same value as NEXT_PUBLIC_APP_URL)
APP_URL=

# Cloudinary (PDF storage, signed URLs)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMTP (signing invites + completion emails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# custom | gmail | outlook | sendgrid
SMTP_PROVIDER=custom
SMTP_RETRIES=2

# --- Optional ---
# Outbound webhook for host-app integration (HMAC signed with SMTP_SECRET)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Optional secret for internal JWTs (must be >= 32 chars)
JWT_SECRET=

# Demo identity injected by the client into x-user-* headers (no real auth)
NEXT_PUBLIC_DEMO_USER_ID=user_1
NEXT_PUBLIC_DEMO_USER_EMAIL=owner@company.com
NEXT_PUBLIC_DEMO_ORG_ID=org_demo

# --- Word → PDF (layout-preserving; works on Vercel without local Office) ---
#
# LOCAL: LibreOffice (recommended after you install it on your PC)
# LIBRE_OFFICE_EXE=C:\Program Files\LibreOffice\program\soffice.exe
LIBRE_OFFICE_EXE=

# PRODUCTION (Vercel): host Gotenberg (free Docker service) and paste its URL:
# GOTENBERG_URL=https://your-gotenberg.up.railway.app
GOTENBERG_URL=

# Word Online / office PC without desktop Word — use Microsoft Graph (see docs/MICROSOFT_GRAPH_SETUP.md)
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_SITE_HOST=yourcompany.sharepoint.com
# MS_GRAPH_SITE_PATH=/sites/QuikSignConvert
# Or set drive id directly: MS_GRAPH_DRIVE_ID=

# LOCAL: auto-uses Microsoft Word when installed (best layout). Set false to force LibreOffice only:
# WORD_PDF_CONVERSION=false
# WINWORD_EXE=C:\Program Files\Microsoft Office\root\Office16\WINWORD.EXE
