{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install --include=optional",
  "framework": "nextjs",
  "functions": {
    "app/api/documents/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/envelopes/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/envelopes/[id]/packet/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/sign/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/sign/approve/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/sign/[token]/download/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/sign/[token]/file/route.ts": { "maxDuration": 60, "memory": 1024 },
    "app/api/sign-documents/save/route.ts": { "maxDuration": 60, "memory": 1024 }
  }
}
